# Values are available in Supabase Project Settings.
# Store real values only in .env.local.
# Do not commit .env.local.
# Use only publishable/anon keys from Supabase Project Settings.
# The MVP does not need a private server key.
# Do not add real keys to README.md or docs.

NEXT_PUBLIC_SUPABASE_URL=
# Use the new Supabase publishable key if your project shows one.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Backward-compatible fallback for projects that still use anon key naming.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
